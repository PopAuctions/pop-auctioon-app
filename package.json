{
  "name": "pop-auctioon-app",
  "main": "expo-router/entry",
  "version": "1.0.0",
  "packageManager": "pnpm@10.27.0",
  "scripts": {
    "start": "expo start",
    "dev": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "test": "jest",
    "test:watch": "jest --watchAll",
    "lint": "pnpm exec expo lint",
    "lint:fix": "pnpm exec expo lint -- --fix",
    "prettier:check": "prettier --check .",
    "prettier:fix": "prettier --write .",
    "type-check": "tsc --noEmit",
    "coverage:open": "pnpm exec open-cli ./coverage/lcov-report/index.html",
    "test:update-snapshots": "jest -u",
    "check-all": "pnpm type-check && pnpm lint:fix && pnpm prettier:fix && pnpm test",
    "build:ios": "eas build --platform ios --profile development",
    "build:ios:prod": "eas build --platform ios --profile production",
    "build:ios:device": "eas build --platform ios --profile development-device",
    "build:ios:internal": "grep -q 'EXPO_PUBLIC_API_KEY' eas.json || (echo '❌ EXPO_PUBLIC_API_KEY not found in eas.json' && exit 1) && eas build --platform ios --profile internal-store",
    "ios:submit": "eas submit -p ios",
    "build:android": "eas build --platform android --profile development",
    "build:android:prod": "eas build --platform android --profile production",
    "build:android:internal": "grep -q 'EXPO_PUBLIC_API_KEY' eas.json || (echo '❌ EXPO_PUBLIC_API_KEY not found in eas.json' && exit 1) && eas build --platform android --profile internal-store",
    "generate-types": "pnpm exec supabase gen types typescript --project-id xvohgpgzvxdwooerdnfb --schema public > ./src/types/supabase.ts"
  },
  "dependencies": {
    "@expo-google-fonts/dev": "^0.4.43",
