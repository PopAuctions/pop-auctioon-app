    "@react-native-vector-icons/fontawesome6": "^12.3.0",
    "@react-navigation/native": "^7.1.26",
    "@sentry/react-native": "~7.2.0",
    "@stripe/stripe-react-native": "0.50.3",
    "@supabase/supabase-js": "^2.90.1",
    "aes-js": "^3.1.2",
    "amazon-ivs-chat-messaging": "^1.1.1",
    "base-64": "^1.0.0",
