# Configuración de pnpm para React Native/Expo
# shamefully-hoist es necesario para compatibilidad con React Native y Metro bundler
shamefully-hoist=true
node-linker=hoisted

# Peer dependencies (Expo las necesita)
auto-install-peers=true
strict-peer-dependencies=false

# Scripts de instalación (Sentry y otros nativos)
enable-pre-post-scripts=true

# Permisos para build scripts de módulos nativos
scripts-allow-build=@sentry/cli,unrs-resolver

# Symlinks pueden causar problemas en Windows con React Native
symlink=false

# Optimizaciones
prefer-frozen-lockfile=false
public-hoist-pattern[]=*eslint*
public-hoist-pattern[]=*prettier*
public-hoist-pattern[]=@babel/*
