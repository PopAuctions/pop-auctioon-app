{
  "expo": {
    "owner": "pop-auctioon",
    "name": "PopAuctioon",
    "slug": "pop-auctioon-app",
    "version": "1.0.1",
    "icon": "./assets/icons/pop-auctioon-icon.png",
    "scheme": "popauctioonapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash/blank.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.popauctioon.popauctioonapp",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true
      },
      "usesAppleSignIn": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/icons/pop-auctioon-icon.png",
        "backgroundColor": "#ffffff"
      },
      "package": "com.popauctioon.popauctioonapp",
      "resizeableActivity": false,
      "predictiveBackGestureEnabled": false,
      "softwareKeyboardLayoutMode": "resize",
      "googleServicesFile": "./google-services.json",
      "notification": {
        "icon": "./assets/icons/pop-auctioon-icon.png",
        "color": "#d75639"
      }
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-notifications",
      "expo-font",
      "expo-apple-authentication",
      "expo-screen-orientation",
      [
        "@sentry/react-native/expo",
        {
          "url": "https://sentry.io/",
          "project": "react-native-pop-auctioon",
          "organization": "pop-auctioon"
        }
      ],
      [
        "expo-localization",
        {
          "supportedLocales": [
            "es",
            "en"
          ]
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "PopAuctioon accesses your photo library so you can update your profile picture or upload images of articles when creating auction listings.",
          "cameraPermission": "PopAuctioon accesses your camera so you can take photos for your profile picture or for articles when creating auction listings."
        }
      ],
      "@sentry/react-native",
      [
        "@stripe/stripe-react-native",
        {}
      ],
      "expo-web-browser",
      "expo-video"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "supportsRTL": true,
      "router": {},
      "eas": {
        "projectId": "2f1d2957-9008-496f-91b7-9484d7b3d4a7"
      }
    }
  }
}